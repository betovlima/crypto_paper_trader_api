# Local development
APP_ENV=development
DATA_DIR=./data

# Railway production: attach a volume. The API automatically uses
# RAILWAY_VOLUME_MOUNT_PATH, which Railway injects at runtime.
# APP_ENV=production
POLL_INTERVAL_SECONDS=15
CORS_ORIGINS=http://localhost:5173

# Required only for direct administrative API calls such as manual stop/consolidation.
# Use a long random value in Railway and do not expose it through any VITE_* variable.
ADMIN_API_KEY=replace-with-a-long-random-secret
