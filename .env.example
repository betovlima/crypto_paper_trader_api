# Local development
APP_ENV=development
DATA_DIR=./data

# Railway production: attach a volume. The API automatically uses
# RAILWAY_VOLUME_MOUNT_PATH, which Railway injects at runtime.
# APP_ENV=production
POLL_INTERVAL_SECONDS=15
CORS_ORIGINS=http://localhost:5173

# Required only for direct administrative API calls such as manual stop/consolidation.
# Use a long random value in Railway and do not expose it through any VITE_* variable.
ADMIN_API_KEY=replace-with-a-long-random-secret

# Autonomous AI Pattern Trader (paper portfolio only)
# Use OBSERVATION to record proposed actions without simulated trades.
AI_PATTERN_MODE=PAPER_AUTONOMOUS
AI_PATTERN_HORIZON_CANDLES=5
AI_PATTERN_MIN_TRAINING_ROWS=240
AI_PATTERN_TRAINING_MAX_ROWS=900
AI_PATTERN_NEIGHBORS=32
AI_PATTERN_CLUSTERS=8
AI_PATTERN_TREE_COUNT=96
AI_PATTERN_BUY_PROBABILITY_THRESHOLD=0.61
AI_PATTERN_SELL_PROBABILITY_THRESHOLD=0.43
AI_PATTERN_MIN_EXPECTED_NET_RETURN=0.0015
AI_PATTERN_MIN_CONFIDENCE=0.52
AI_PATTERN_MAX_SPREAD_RATE=0.006
