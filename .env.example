# Application
APP_ENV=development
LOG_LEVEL=INFO
DATA_DIR=./data
POLL_INTERVAL_SECONDS=15
CORS_ORIGINS=http://localhost:5173
ADMIN_API_KEY=replace-with-a-long-random-secret

# MEXC public Spot market data (PAPER_ONLY)
MEXC_BASE_URL=https://api.mexc.com
HTTP_TIMEOUT_SECONDS=20
DEFAULT_MARKET=BTCUSDT
DEFAULT_EXECUTION_TIMEFRAME=30min
DEFAULT_TREND_TIMEFRAME=1hour
DEFAULT_DURATION_HOURS=24
DEFAULT_INITIAL_CAPITAL=1000

# MEXC API Spot execution-cost assumptions used by the simulator
VIP_LEVEL=API_SPOT
MAKER_FEE_RATE=0.0
TAKER_FEE_RATE=0.0005
USE_PUBLIC_MARKET_FEE_RATES=false
MX_FEE_DISCOUNT_ENABLED=false
MX_FEE_DISCOUNT_PCT=0.20
FALLBACK_SPREAD_RATE=0.0002
SLIPPAGE_RATE=0.0005
POSITION_ALLOCATION=0.95

# Adaptive Strategy Research Selector
SELECTOR_MIN_CONFIDENCE=0.60
SELECTOR_MIN_EXPECTED_NET_RETURN=0.0030
SELECTOR_MIN_REWARD_RISK_RATIO=1.30
SELECTOR_MODEL_VERSION=ADAPTIVE-RESEARCH-SELECTOR-v1

# Optional web research. Keep OPENAI_API_KEY only in the API service.
ADAPTIVE_RESEARCH_WEB_ENABLED=true
OPENAI_API_KEY=
ADAPTIVE_RESEARCH_OPENAI_MODEL=gpt-5
ADAPTIVE_RESEARCH_AI_REVIEW_ENABLED=true
ADAPTIVE_RESEARCH_OPENAI_REVIEW_MODEL=gpt-5
ADAPTIVE_RESEARCH_WEB_TIMEOUT_SECONDS=45
ADAPTIVE_RESEARCH_INTERVAL_HOURS=12
ADAPTIVE_RESEARCH_RETRY_MINUTES=30
ADAPTIVE_RESEARCH_MIN_CANDLES=800
ADAPTIVE_RESEARCH_VALIDATION_ROWS=240
ADAPTIVE_RESEARCH_WALK_FORWARD_FOLDS=3
ADAPTIVE_RESEARCH_MAX_CANDIDATES=8
ADAPTIVE_RESEARCH_MIN_TRADES=20
ADAPTIVE_RESEARCH_MIN_PROFIT_FACTOR=1.20
ADAPTIVE_RESEARCH_MAX_DRAWDOWN_PCT=0.10
ADAPTIVE_RESEARCH_MIN_STABILITY=0.67
ADAPTIVE_RESEARCH_MIN_VALIDATION_SCORE=60

# Intraday strategies
LARRY_BREAKOUT_LOOKBACK=12
LARRY_BREAKOUT_FACTOR=0.50
LARRY_BREAKOUT_STOP_ATR=1.20
LARRY_BREAKOUT_TARGET_ATR=1.80
EMA_PULLBACK_TOUCH_ATR=0.25

# Independent AI Pattern Trader
AI_PATTERN_MODE=PAPER_AUTONOMOUS
AI_PATTERN_HORIZON_CANDLES=5
AI_PATTERN_MIN_TRAINING_ROWS=1000
AI_PATTERN_TRAINING_MAX_ROWS=8000
AI_PATTERN_NEIGHBORS=32
AI_PATTERN_CLUSTERS=8
AI_PATTERN_TREE_COUNT=96
AI_PATTERN_BUY_PROBABILITY_THRESHOLD=0.61
AI_PATTERN_SELL_PROBABILITY_THRESHOLD=0.43
AI_PATTERN_MIN_EXPECTED_NET_RETURN=0.0015
AI_PATTERN_MIN_CONFIDENCE=0.52
AI_PATTERN_MAX_SPREAD_RATE=0.006
AI_PATTERN_RECENCY_HALF_LIFE_DAYS=120

# Separate long-history AI database
AI_DATABASE_URL=sqlite:///./data/ai_pattern_trader.db
AI_HISTORY_TARGET_CANDLES=8760
AI_HISTORY_BACKFILL_BATCHES_PER_CYCLE=12

# Railway production: attach a persistent volume to the API service.
# Railway injects RAILWAY_VOLUME_MOUNT_PATH automatically.
# APP_ENV=production


# Independent AI Opportunity Scanner
AI_SCANNER_ENABLED=true
AI_SCANNER_INTERVAL_SECONDS=300
AI_SCANNER_UNIVERSE_SIZE=10
AI_SCANNER_RESULT_LIMIT=5
AI_SCANNER_QUOTE_ASSET=USDT
AI_SCANNER_EXECUTION_TIMEFRAME=30min
AI_SCANNER_TREND_TIMEFRAME=1hour
AI_SCANNER_CANDLE_LIMIT=3000
AI_SCANNER_MIN_TRAINING_ROWS=800
AI_SCANNER_TRAINING_WINDOW=2000
AI_SCANNER_VALIDATION_ROWS=240
AI_SCANNER_RECENT_REGIME_ROWS=500
AI_SCANNER_CANDIDATE_WINDOWS=800,1000,2000,3000
