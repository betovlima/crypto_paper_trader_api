# Local backend configuration. Copy this file to .env in the API project root.
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
ADMIN_API_KEY=replace-with-a-local-admin-key

# Legacy compatibility name: enables optional OpenAI hypotheses; no web search is used.
ADAPTIVE_RESEARCH_WEB_ENABLED=true
ADAPTIVE_RESEARCH_AI_REVIEW_ENABLED=true
OPENAI_API_KEY=replace-with-your-server-side-key
ADAPTIVE_RESEARCH_OPENAI_MODEL=gpt-5
ADAPTIVE_RESEARCH_OPENAI_REVIEW_MODEL=gpt-5

# Adaptive time-series pattern research for the single selected experiment asset.
# The first analysis may start at the minimum; the service keeps expanding toward the target.
ADAPTIVE_RESEARCH_MIN_CANDLES=800
ADAPTIVE_RESEARCH_TARGET_CANDLES=10000
ADAPTIVE_RESEARCH_MAX_HISTORY_CANDLES=30000
ADAPTIVE_PATTERN_WINDOW_CANDLES=24
ADAPTIVE_PATTERN_HORIZON_CANDLES=1
ADAPTIVE_PATTERN_NEIGHBORS=64
ADAPTIVE_RESEARCH_OPENAI_TIMEOUT_SECONDS=90
ADAPTIVE_RESEARCH_OPENAI_ATTEMPTS=2
